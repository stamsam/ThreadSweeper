{
  "manifest_version": 3,
  "name": "ThreadSweeper",
  "description": "Clean ChatGPT sidebar threads with safety guardrails.",
  "version": "0.1.0",
  "permissions": ["storage"],
  "host_permissions": ["https://chatgpt.com/*"],
  "action": {
    "default_title": "ThreadSweeper",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
