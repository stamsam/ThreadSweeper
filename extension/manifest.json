{
  "manifest_version": 3,
  "name": "ThreadSweeper",
  "description": "Clean ChatGPT sidebar threads with safety guardrails.",
  "version": "0.1.3",
  "icons": {
    "16": "icons/threadsweeper-16.png",
    "32": "icons/threadsweeper-32.png",
    "48": "icons/threadsweeper-48.png",
    "128": "icons/threadsweeper-128.png"
  },
  "permissions": ["storage"],
  "host_permissions": ["https://chatgpt.com/*"],
  "action": {
    "default_title": "ThreadSweeper",
    "default_icon": {
      "16": "icons/threadsweeper-16.png",
      "32": "icons/threadsweeper-32.png"
    },
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
